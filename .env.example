# 伺服器環境 development | production
NODE_ENV=development
NEXT_PUBLIC_ENV=development
NEXT_PUBLIC_IS_BONUS=true
IS_BONUS=true

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=A9xt7QvLp
POSTGRES_DB=project_a

# Prisma 連線字串也需同步 (Prisma schema 依賴此變數)
# DATABASE_URL 是 給容器環境用的
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}?schema=public"

# Google OAuth 設定
# 從 Google Cloud Console 取得
# GOOGLE_CLIENT_ID=your_google_client_id_here
# GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# NextAuth 設定
# 使用 openssl rand -base64 32 生成
NEXTAUTH_SECRET=your_nextauth_secret_here
# 網站 URL
NEXTAUTH_URL=http://localhost:3000


# JWT_SECRET=your_jwt_secret_here

# 關閉匿名的使用資訊蒐集（例如你用了哪些功能、建置速度、錯誤率）
NEXT_TELEMETRY_DISABLED=1

# Google OAuth
# 用戶端編號
GOOGLE_CLIENT_ID=your_google_client_id_here
# 用戶端密碼
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Docker 用戶
UID=1000
GID=1000

#------------------------------
# Cloudflare R2 設定
#------------------------------

R2_ACCOUNT_ID="你的_ACCOUNT_ID"
R2_ACCESS_KEY_ID="你的_ACCESS_KEY_ID"
R2_SECRET_ACCESS_KEY="你的_SECRET_ACCESS_KEY"
R2_BUCKET_NAME="bc-erp-attachments"
# Endpoint 格式：https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT="https://你的_ACCOUNT_ID.r2.cloudflarestorage.com"


#------------------------------
# 以下是 DEV 和 CI 需要的設定
#------------------------------

# 本機開發 DB（例如 docker compose dev 的 db）
DATABASE_URL_DEV="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@127.0.0.1:5432/${POSTGRES_DB}?schema=public"

# VPS3 遠端 DB（透過 SSH tunnel 後，WSL 本機 port 15432）
DATABASE_URL_VPS3="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@127.0.0.1:15432/${POSTGRES_DB}?schema=public"

# CR Sync API Token（GitHub Actions 同步規格摘要用）
# 使用 openssl rand -base64 32 生成
# CR_SYNC_API_TOKEN=your_sync_api_token_here

# Gemini AI API（知識文章自動標籤）
# 從 Google AI Studio 取得：https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

#------------------------------
# Email SMTP 設定（Nodemailer）
#------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_email@gmail.com
SMTP_PASS=your_smtp_app_password
# 寄件者顯示地址（必須是在 Brevo/SMTP 服務商後台驗證過的 Email）
SMTP_FROM=noreply@yourdomain.com