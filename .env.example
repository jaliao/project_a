# 伺服器環境 development | production
NODE_ENV=development
NEXT_PUBLIC_ENV=development
NEXT_PUBLIC_IS_BONUS=true
IS_BONUS=true

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=A9xt7QvLp
POSTGRES_DB=project_a

# Prisma 連線字串也需同步 (Prisma schema 依賴此變數)
# DATABASE_URL 是 給容器環境用的
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}?schema=public"

# Google OAuth 設定
# 從 Google Cloud Console 取得
# GOOGLE_CLIENT_ID=your_google_client_id_here
# GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# NextAuth 設定
# 使用 openssl rand -base64 32 生成
NEXTAUTH_SECRET=your_nextauth_secret_here
# 網站 URL
NEXTAUTH_URL=http://localhost:3000


# JWT_SECRET=your_jwt_secret_here

# 關閉匿名的使用資訊蒐集（例如你用了哪些功能、建置速度、錯誤率）
NEXT_TELEMETRY_DISABLED=1

#------------------------------
# ECPay 物流（超商門市選擇器）
#------------------------------
# 測試帳號（公開共用）：MerchantID=2000132, HashKey=5294y06JbISpM5x9, HashIV=v77hoKGq4kWxNNIS
# 正式環境請填入向綠界申請的物流帳號
ECPAY_LOGISTICS_MERCHANT_ID=2000132
ECPAY_LOGISTICS_HASH_KEY=5294y06JbISpM5x9
ECPAY_LOGISTICS_HASH_IV=v77hoKGq4kWxNNIS
# 公開可達的 HTTPS base URL（ECPay 需 POST 回此位址）
# 本機開發：使用 ngrok / cloudflare tunnel URL（例如 https://xxxx.ngrok.io）
# 留空則自動啟用 mock 模式，無需外部連線即可測試
ECPAY_LOGISTICS_SERVER_URL=
# ECPay 物流 MapCVS 端點（預設正式環境，如需測試環境請設為 stage URL）
# 正式：https://logistics.ecpay.com.tw/Express/map（預設，不填即使用此值）
# 測試：https://logistics-stage.ecpay.com.tw/Express/map
ECPAY_LOGISTICS_MAP_URL=

# Google OAuth
# 用戶端編號
GOOGLE_CLIENT_ID=your_google_client_id_here
# 用戶端密碼
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Docker 用戶
UID=1000
GID=1000

#------------------------------
# Cloudflare R2 設定
#------------------------------

R2_ACCOUNT_ID="你的_ACCOUNT_ID"
R2_ACCESS_KEY_ID="你的_ACCESS_KEY_ID"
R2_SECRET_ACCESS_KEY="你的_SECRET_ACCESS_KEY"
R2_BUCKET_NAME="bc-erp-attachments"
# Endpoint 格式：https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT="https://你的_ACCOUNT_ID.r2.cloudflarestorage.com"


#------------------------------
# 以下是 DEV 和 CI 需要的設定
#------------------------------

# 本機開發 DB（例如 docker compose dev 的 db）
DATABASE_URL_DEV="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@127.0.0.1:5432/${POSTGRES_DB}?schema=public"

# VPS3 遠端 DB（透過 SSH tunnel 後，WSL 本機 port 15432）
DATABASE_URL_VPS3="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@127.0.0.1:15432/${POSTGRES_DB}?schema=public"

# CR Sync API Token（GitHub Actions 同步規格摘要用）
# 使用 openssl rand -base64 32 生成
# CR_SYNC_API_TOKEN=your_sync_api_token_here

# Gemini AI API（知識文章自動標籤）
# 從 Google AI Studio 取得：https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

#------------------------------
# Email SMTP 設定（Nodemailer）
#------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_email@gmail.com
SMTP_PASS=your_smtp_app_password
# 寄件者顯示地址（必須是在 Brevo/SMTP 服務商後台驗證過的 Email）
SMTP_FROM=noreply@yourdomain.com

# Seed 初始化管理員密碼（不設定則使用預設值 Admin@1234）
# 生產環境請務必設定強密碼，首次登入後系統會強制要求變更
# SEED_ADMIN_PASSWORD=your_strong_password_here

# 會員刪除功能（預設關閉，設為 true 才會在後台顯示刪除按鈕）
ENABLE_MEMBER_DELETE=false

# 會員資料完整度強制轉導（預設啟用）
# true（或未設定）：已登入會員若 realName/phone 未填，強制導向 Profile 頁填寫
# false：停用強制轉導，改以 Dashboard Banner 提醒（適合開發/測試環境）
REQUIRE_PROFILE_COMPLETION=true

#------------------------------
# Cloudflare Tunnel
#------------------------------

# Cloudflare Tunnel Token（project-a-dev.blockcode.com.tw）
CF_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here
