/**
 * ----------------------------------------------
 * Prisma Schema - 使用者與認證模型
 * 2026-03-23
 * prisma/schema/user.prisma
 * ----------------------------------------------
 */

// ==========================================
// 使用者角色枚舉
// ==========================================
enum UserRole {
  user
  admin
  superadmin
}

// ==========================================
// 性別枚舉
// ==========================================
enum Gender {
  male
  female
  unspecified
}

// ==========================================
// 顯示名稱模式枚舉
// ==========================================
enum DisplayNameMode {
  chinese // 使用中文名稱（nickname → realName）
  english // 使用英文名稱（englishName → name）
}

// ==========================================
// 主要使用者模型
// ==========================================
model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique // 登入帳號，唯一且不可變
  emailVerified DateTime?
  name          String?
  image         String?
  role          UserRole  @default(user)

  // 啟動靈人身分識別
  spiritId String? @unique // 格式：PA + YY + XXXX

  // 密碼管理
  passwordHash   String? // Google-only 用戶為 null
  isTempPassword Boolean @default(false) // 臨時密碼強制變更標記

  // 通訊 Email（獨立於登入帳號）
  commEmail      String?
  isCommVerified Boolean @default(false)

  // 個人資料
  realName        String?
  englishName     String? // 英文名稱
  nickname        String? // 自訂暱稱（最多 20 字）
  phone           String?
  isPhoneVerified Boolean         @default(false)
  address         String?
  gender          Gender          @default(unspecified)
  displayNameMode DisplayNameMode @default(chinese)

  // 學習等級（0=未完成任何課程；1~4=已完成啟動靈人對應等級）
  learningLevel Int @default(0)

  // 所屬教會/單位
  churchType  ChurchType @default(none)
  churchId    Int?
  church      Church?    @relation(fields: [churchId], references: [id], onDelete: SetNull)
  churchOther String? // churchType = other 時的自填文字

  // 第三方帳號（保留欄位）
  lineId String? @unique

  // 時間戳記
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  // NextAuth 關聯
  accounts Account[]

  // 課程訂購關聯
  courseOrders CourseOrder[]

  // 課程邀請關聯
  courseInvites     CourseInvite[]
  inviteEnrollments InviteEnrollment[]

  // 通知關聯
  notifications Notification[]

  @@map("users")
}

// ==========================================
// NextAuth - OAuth 帳號關聯表
// ==========================================
model Account {
  id                String  @id @default(cuid())
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// ==========================================
// Spirit ID 計數器（原子遞增，跨年重置）
// ==========================================
model SpiritIdCounter {
  year Int
  seq  Int @default(0)

  @@id([year])
  @@map("spirit_id_counters")
}

// ==========================================
// 密碼重設 Token（TTL 1 小時，一次性使用）
// ==========================================
model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("password_reset_tokens")
}

// ==========================================
// 通訊 Email 驗證 Token（TTL 24 小時）
// ==========================================
model EmailVerificationToken {
  id        String    @id @default(cuid())
  token     String    @unique
  email     String // 欲驗證的通訊 Email
  userId    String    @db.Uuid
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("email_verification_tokens")
}

// ==========================================
// 系統通知
// ==========================================
model Notification {
  id        Int       @id @default(autoincrement())
  userId    String    @db.Uuid
  title     String
  body      String    @db.Text
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}

// ==========================================
// Email 白名單（原有機制，保留相容性）
// ==========================================
model WhitelistedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("whitelisted_emails")
}
