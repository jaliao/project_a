// ==========================================
// 課程目錄
// ==========================================
model CourseCatalog {
  id        Int     @id @default(autoincrement())
  label     String // 顯示名稱（可動態修改）
  isActive  Boolean @default(false) // 是否開放開課與報名
  sortOrder Int     @default(0) // 顯示排序

  // 先修課程（多對多自關聯）
  prerequisites  CourseCatalog[] @relation("CoursePrerequisites")
  prerequisiteOf CourseCatalog[] @relation("CoursePrerequisites")

  invites CourseInvite[]

  @@map("course_catalogs")
}
