/**
 * ----------------------------------------------
 * Prisma Schema - 課程邀請模型
 * 2026-03-23 (Updated: 2026-03-24)
 * prisma/schema/course-invite.prisma
 * ----------------------------------------------
 */

// ==========================================
// 課程等級枚舉
// ==========================================
enum CourseLevel {
  level1 // 啟動靈人 1
  level2 // 啟動靈人 2
  level3 // 啟動靈人 3（未開放）
  level4 // 啟動靈人 4（未開放）
}

// ==========================================
// 報名狀態枚舉
// ==========================================
enum EnrollmentStatus {
  pending // 待審核
  approved // 已核准
}

// ==========================================
// 書籍選擇枚舉
// ==========================================
enum MaterialChoice {
  none // 無須購買
  traditional // 繁體教材
  simplified // 簡體教材
}

// ==========================================
// 課程邀請主體
// ==========================================
model CourseInvite {
  id Int @id @default(autoincrement())

  title       String // 課程名稱（可自訂，預設為「{講師} 的 {課程}」）
  courseLevel CourseLevel @default(level1) // 課程等級
  maxCount    Int // 預計人數

  expiredAt  DateTime? // 邀請截止日期（選填）
  courseDate String? // 預計開課日期（YYYY/MM/DD 字串，選填）
  notes      String? // 備註（選填）

  // 關聯 CourseOrder（選填）
  courseOrderId Int?
  courseOrder   CourseOrder? @relation(fields: [courseOrderId], references: [id])

  // 建立者
  createdById String @db.Uuid
  createdBy   User   @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())

  // 取消課程
  cancelledAt  DateTime? // 取消時間（有值即代表已取消）
  cancelReason String? // 取消原因文字

  // 課程進行中
  startedAt DateTime? // 開始授課時間（有值即代表進行中）

  // 結業
  completedAt DateTime? // 結業時間（有值即代表已結業）

  enrollments InviteEnrollment[]

  @@map("course_invites")
}

// ==========================================
// 學員報名記錄
// ==========================================
model InviteEnrollment {
  id       Int    @id @default(autoincrement())
  inviteId Int
  userId   String @db.Uuid

  invite CourseInvite @relation(fields: [inviteId], references: [id])
  user   User         @relation(fields: [userId], references: [id])

  status         EnrollmentStatus @default(pending) // 申請狀態
  materialChoice MaterialChoice   @default(none) // 書籍選擇

  joinedAt          DateTime  @default(now())
  graduatedAt       DateTime? // 結業時間（有值即代表通過結業）
  nonGraduateReason String? // 未結業原因（insufficient_time / other）

  @@unique([inviteId, userId])
  @@map("invite_enrollments")
}
